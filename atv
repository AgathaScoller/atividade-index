<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Gamer Store</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    font-family: Arial, sans-serif;
    background-color:#f4f4f4;
}
.navbar-brand{
    font-weight:bold;
}
.carousel img{
    height:450px;
    object-fit:cover;
}
.card img{
    height:200px;
    object-fit:cover;
}
#novidades{
    background:#111;
    color:#fff;
}
footer{
    background:#111;
    color:#fff;
}
.login-card{
    max-width:350px;
    margin:auto;
}
@media(max-width:768px){
    .carousel img{
        height:250px;
    }
}
</style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
<div class="container">
<a class="navbar-brand">GamerStore</a>
<button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#menu">
<span class="navbar-toggler-icon"></span>
</button>
<div class="collapse navbar-collapse" id="menu">
<ul class="navbar-nav ms-auto">
<li class="nav-item"><a class="nav-link" href="#">Home</a></li>
<li class="nav-item"><a class="nav-link" href="#destaques">Destaques</a></li>
<li class="nav-item"><a class="nav-link" href="#novidades">Novidades</a></li>
<li class="nav-item"><a class="nav-link" href="#login">Login</a></li>
</ul>
</div>
</div>
</nav>

<div id="banner" class="carousel slide" data-bs-ride="carousel">
<div class="carousel-inner">
<div class="carousel-item active">
<img src="https://images.unsplash.com/photo-1603481546579-65d935ba1d4a" class="d-block w-100">
</div>
<div class="carousel-item">
<img src="https://images.unsplash.com/photo-1593642634315-48f5414c3ad9" class="d-block w-100">
</div>
</div>
</div>

<section id="destaques" class="container mt-5">
<h2 class="text-center">Produtos em Destaque</h2>
<div class="row mt-4">
<div class="col-md-4">
<div class="card">
<img src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7" class="card-img-top">
<div class="card-body">
<h5 class="card-title">Teclado Gamer</h5>
<p class="card-text">Teclado mecânico RGB.</p>
<button class="btn btn-primary btnComprar">Comprar</button>
</div>
</div>
</div>
<div class="col-md-4">
<div class="card">
<img src="https://images.unsplash.com/photo-1598550476439-6847785fcea6" class="card-img-top">
<div class="card-body">
<h5 class="card-title">Mouse Gamer</h5>
<p class="card-text">Alta precisão.</p>
<button class="btn btn-primary btnComprar">Comprar</button>
</div>
</div>
</div>
<div class="col-md-4">
<div class="card">
<img src="https://images.unsplash.com/photo-1593642702821-c8da6771f0c6" class="card-img-top">
<div class="card-body">
<h5 class="card-title">Headset Gamer</h5>
<p class="card-text">Som surround.</p>
<button class="btn btn-primary btnComprar">Comprar</button>
</div>
</div>
</div>
</div>
</section>

<section id="novidades" class="mt-5 p-5 text-center">
<h2>Novidades</h2>
<p>Lançamentos e acessórios do universo gamer.</p>
</section>

<section class="container mt-5">
<h2 class="text-center">Galeria</h2>
<div class="row mt-4">
<div class="col-md-3"><img class="img-fluid" src="https://images.unsplash.com/photo-1552820728-8b83bb6b773f"></div>
<div class="col-md-3"><img class="img-fluid" src="https://images.unsplash.com/photo-1598550483190-5bde93d11a19"></div>
<div class="col-md-3"><img class="img-fluid" src="https://images.unsplash.com/photo-1587202372775-e229f172b9d7"></div>
<div class="col-md-3"><img class="img-fluid" src="https://images.unsplash.com/photo-1603481546579-65d935ba1d4a"></div>
</div>
</section>

<section id="login" class="container mt-5 mb-5">
<div class="card login-card p-4">
<h3 class="text-center">Login</h3>
<form id="loginForm">
<div class="mb-3">
<label>Email</label>
<input type="email" id="email" class="form-control" required>
</div>
<div class="mb-3">
<label>Senha</label>
<input type="password" id="senha" class="form-control" required>
</div>
<button class="btn btn-dark w-100">Entrar</button>
</form>
<p class="text-center mt-3" id="msg"></p>
</div>
</section>

<footer class="text-center p-3">
<p>© 2026 GamerStore</p>
</footer>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
$(function(){
    $(".btnComprar").click(function(){
        alert("Produto adicionado ao carrinho");
    });

    $("#loginForm").submit(function(e){
        e.preventDefault();
        let email=$("#email").val();
        let senha=$("#senha").val();
        if(email!="" && senha!=""){
            $("#msg").html("<span style='color:green'>Login realizado</span>");
        }else{
            $("#msg").html("<span style='color:red'>Dados inválidos</span>");
        }
    });
});
</script>

</body>
</html>
